<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened Runtime resource-access entitlement so CoreLocation works.
	     Deliberately NO App Sandbox: it would block the SkyLight private symbol
	     used for system-wide appearance switching (see CLAUDE.md). -->
	<key>com.apple.security.personal-information.location</key>
	<true/>
</dict>
</plist>
